{
  "name": "andrewford-co-nz-11ty",
  "version": "3.2.1",
  "description": "andrewford.co.nz blog in 11ty",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "scripts": {
    "api": "node api/server.mjs",
    "api:dev": "PORT=3080 NODE_ENV=development node api/server.mjs",
    "article": "bash article.sh",
    "benchmark": "DEBUG=Eleventy:Benchmark* NODE_ENV=development npx @11ty/eleventy",
    "build:dev": "NODE_ENV=development npx @11ty/eleventy",
    "build": "NODE_ENV=production npx @11ty/eleventy",
    "clear": "rm -rf _site && rm -rf .cache",
    "debug": "DEBUG=Eleventy* NODE_ENV=development npx @11ty/eleventy",
    "debugstart": "DEBUG=Eleventy* NODE_ENV=development npx @11ty/eleventy --serve --quiet",
    "dev:ui": "NODE_ENV=development npx @11ty/eleventy --serve",
    "dev": "concurrently \"npm run api:dev\" \"npm run dev:ui\"",
    "docker:build": "docker build -t andrewford-blog .",
    "docker:run": "docker run -p 3000:3000 --env-file .env andrewford-blog",
    "docker:dev": "docker-compose up --build",
    "docker:prod": "docker-compose up app --build",
    "genvector:simple": "node tools/generateSimpleVectorStore.mjs",
    "genvector": "node tools/generateVectorStore.mjs",
    "markdownlint": "markdownlint-cli2 --fix \"content/**/*.md\" \"#node_modules\" --config .markdownlint.json",
    "note": "bash note.sh",
    "perfbudget": "lighthouse http://localhost:3080 --budget-path=./budget.json --view",
    "postinstall": "npm rebuild faiss-node",
    "prettier:check": "prettier --check \"**/*.{md,*js,json,yml,css}\" --ignore-path .gitignore",
    "prettier": "prettier --write \"**/*.{md,*js,json,yml,css}\" --ignore-path .gitignore",
    "serve": "npx http-server _site -p 3000",
    "start": "NODE_ENV=development npx @11ty/eleventy --serve",
    "test": "npm run test:e2e:quick",
    "test:all": "npm run test:e2e:essential && npm run test:e2e:links",
    "test:e2e": "playwright test",
    "test:e2e:essential": "playwright test tests/e2e/basic.spec.js tests/e2e/chatbot-simple.spec.js tests/e2e/chatbot-quick.spec.js --project=chromium",
    "test:e2e:links": "node --test tests/e2e/site-links.spec.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:quick": "playwright test tests/e2e/chatbot-quick.spec.js --project=chromium",
    "test:e2e:simple": "playwright test tests/e2e/chatbot-simple.spec.js --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewjamesford/andrewford-co-nz-11ty.git"
  },
  "author": {
    "name": "Andrew Ford",
    "email": "hireme@andrewford.co.nz",
    "url": "https://andrewford.co.nz/"
  },
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/andrewjamesford/andrewford-co-nz-11ty/issues"
  },
  "homepage": "https://github.com/andrewjamesford/andrewford-co-nz-11ty#readme",
  "overrides": {
    "@11ty/eleventy": {
      "liquidjs": "10.27.0",
      "picomatch": "4.0.4"
    },
    "@langchain/langgraph": {
      "uuid": "11.1.1"
    },
    "@langchain/langgraph-checkpoint": {
      "uuid": "11.1.1"
    },
    "@sentry/node": {
      "brace-expansion": "2.0.3"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "axios": "1.16.1",
    "fdir": {
      "picomatch": "4.0.4"
    },
    "follow-redirects": "1.16.0",
    "langsmith": "0.7.3",
    "lodash-es": "4.18.1",
    "path-to-regexp": "8.4.2",
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "yauzl": "3.2.1"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@11ty/eleventy-fetch": "5.1.2",
    "@11ty/eleventy-img": "6.0.4",
    "@11ty/eleventy-navigation": "1.0.5",
    "@11ty/eleventy-plugin-bundle": "3.0.7",
    "@11ty/eleventy-plugin-rss": "3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.2",
    "@playwright/test": "1.60.0",
    "concurrently": "9.2.1",
    "dotenv": "16.6.1",
    "eleventy-plugin-youtube-embed": "1.13.2",
    "http-server": "14.1.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lighthouse": "12.8.2",
    "luxon": "3.7.2",
    "markdown-it-anchor": "9.2.0",
    "markdown-it-footnote": "4.0.0",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "supertest": "7.2.2"
  },
  "dependencies": {
    "@langchain/classic": "1.0.34",
    "@langchain/community": "1.1.29",
    "@langchain/core": "1.1.48",
    "@langchain/openai": "1.4.7",
    "@langchain/textsplitters": "1.0.1",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dompurify": "3.4.7",
    "express": "5.2.1",
    "faiss-node": "0.5.1",
    "html-minifier-terser": "7.2.0",
    "langchain": "1.4.2",
    "node-fetch": "3.3.2",
    "sanitize-html": "2.17.4",
    "winston": "3.19.0"
  }
}
